{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#0A0A0A",
    "blackSoft": "#111111",
    "blackElevated": "#1A1A1A",
    "grayDark": "#262626",
    "grayMid": "#404040",
    "grayLight": "#8A8A8A",
    "white": "#E8E8E8",
    "red": "#FF3333",
    "redBright": "#FF5555",
    "redDim": "#CC2222",
    "redSoft": "#FF7777",
    "redGlow": "#FFAAAA",
    "salmon": "#FFAA88",
    "green": "#44FF44",
    "greenDim": "#228822",
    "orange": "#FF8800"
  },
  "theme": {
    "primary": {
      "dark": "red",
      "light": "redDim"
    },
    "secondary": {
      "dark": "redSoft",
      "light": "redDim"
    },
    "accent": {
      "dark": "redBright",
      "light": "red"
    },
    "error": {
      "dark": "red",
      "light": "redDim"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "green",
      "light": "greenDim"
    },
    "info": {
      "dark": "redBright",
      "light": "redDim"
    },
    "text": {
      "dark": "white",
      "light": "black"
    },
    "textMuted": {
      "dark": "grayLight",
      "light": "grayMid"
    },
    "background": {
      "dark": "black",
      "light": "white"
    },
    "backgroundPanel": {
      "dark": "blackSoft",
      "light": "#F0F0F0"
    },
    "backgroundElement": {
      "dark": "blackElevated",
      "light": "#E0E0E0"
    },
    "border": {
      "dark": "grayDark",
      "light": "#D0D0D0"
    },
    "borderActive": {
      "dark": "grayMid",
      "light": "#A0A0A0"
    },
    "borderSubtle": {
      "dark": "#1F1F1F",
      "light": "#E5E5E5"
    },
    "diffAdded": {
      "dark": "green",
      "light": "greenDim"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "redDim"
    },
    "diffContext": {
      "dark": "grayLight",
      "light": "grayMid"
    },
    "diffHunkHeader": {
      "dark": "grayMid",
      "light": "grayLight"
    },
    "diffHighlightAdded": {
      "dark": "green",
      "light": "greenDim"
    },
    "diffHighlightRemoved": {
      "dark": "redBright",
      "light": "redDim"
    },
    "diffAddedBg": {
      "dark": "#0D1F0D",
      "light": "#E8F5E8"
    },
    "diffRemovedBg": {
      "dark": "#1F0D0D",
      "light": "#F5E8E8"
    },
    "diffContextBg": {
      "dark": "blackSoft",
      "light": "#F5F5F5"
    },
    "diffLineNumber": {
      "dark": "grayDark",
      "light": "#C0C0C0"
    },
    "diffAddedLineNumberBg": {
      "dark": "#0D1F0D",
      "light": "#E8F5E8"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#1F0F0F",
      "light": "#F5E8E8"
    },
    "markdownText": {
      "dark": "white",
      "light": "black"
    },
    "markdownHeading": {
      "dark": "red",
      "light": "redDim"
    },
    "markdownLink": {
      "dark": "redBright",
      "light": "redDim"
    },
    "markdownLinkText": {
      "dark": "redSoft",
      "light": "redDim"
    },
    "markdownCode": {
      "dark": "salmon",
      "light": "#CC4400"
    },
    "markdownBlockQuote": {
      "dark": "grayLight",
      "light": "grayMid"
    },
    "markdownEmph": {
      "dark": "redSoft",
      "light": "redDim"
    },
    "markdownStrong": {
      "dark": "redGlow",
      "light": "redDim"
    },
    "markdownHorizontalRule": {
      "dark": "grayDark",
      "light": "#D0D0D0"
    },
    "markdownListItem": {
      "dark": "red",
      "light": "redDim"
    },
    "markdownListEnumeration": {
      "dark": "redBright",
      "light": "redDim"
    },
    "markdownImage": {
      "dark": "redSoft",
      "light": "redDim"
    },
    "markdownImageText": {
      "dark": "redGlow",
      "light": "redDim"
    },
    "markdownCodeBlock": {
      "dark": "white",
      "light": "black"
    },
    "syntaxComment": {
      "dark": "grayMid",
      "light": "#999999"
    },
    "syntaxKeyword": {
      "dark": "red",
      "light": "redDim"
    },
    "syntaxFunction": {
      "dark": "redSoft",
      "light": "#CC3333"
    },
    "syntaxVariable": {
      "dark": "white",
      "light": "#222222"
    },
    "syntaxString": {
      "dark": "salmon",
      "light": "#CC5522"
    },
    "syntaxNumber": {
      "dark": "redBright",
      "light": "#AA1111"
    },
    "syntaxType": {
      "dark": "redGlow",
      "light": "#CC3333"
    },
    "syntaxOperator": {
      "dark": "redBright",
      "light": "#CC2222"
    },
    "syntaxPunctuation": {
      "dark": "grayLight",
      "light": "#666666"
    }
  }
}
